# ──────────────────────────────────────────────────────────
# BugPilot environment variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# Option A: local PostgreSQL (default for docker-compose)
DATABASE_URL=postgresql+asyncpg://bugpilot:bugpilot@localhost:5432/bugpilot

# Option B: Supabase transaction-mode pooler (recommended for production)
# Find this in: Supabase dashboard → Project Settings → Database → Connection string → URI
# Use port 6543 (PgBouncer) for serverless/multi-tenant deployments.
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Option C: Supabase direct connection (single long-lived process, port 5432)
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Encryption ──────────────────────────────────────────────
# Leave empty to auto-generate on startup (not suitable for multi-instance deploys)
FERNET_KEY=

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Supabase ────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Connectors ──────────────────────────────────────────────
CONNECTOR_TIMEOUT_SECONDS=30
CONNECTOR_MAX_RETRIES=3

# ── Evidence ────────────────────────────────────────────────
EVIDENCE_TTL_MINUTES=10
