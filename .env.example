# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>
SUPABASE_ANON_KEY=<anon_key>

# ── Frontend (Vite) ───────────────────────────────────────────
# These are exposed to the browser — use the anon key, NOT the service key
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon_key>
# Direct PostgreSQL connection (for worker raw SQL and AGE queries)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# For local dev (after supabase start):
# SUPABASE_URL=http://localhost:54321
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_SQS_P1_URL=https://sqs.us-east-1.amazonaws.com/<account>/bugpilot-p1.fifo
AWS_SQS_P2_URL=https://sqs.us-east-1.amazonaws.com/<account>/bugpilot-p2.fifo
AWS_SQS_RETRO_URL=https://sqs.us-east-1.amazonaws.com/<account>/bugpilot-retro.fifo
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:<account>:bugpilot-investigation-complete

# ── LLM ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── GitHub Connector ─────────────────────────────────────────
GITHUB_CONNECTOR_APP_ID=12345
# Private key stored in AWS Secrets Manager:
GITHUB_CONNECTOR_PRIVATE_KEY_SECRET=bugpilot/github/private-key

# ── Slack ─────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=<from Slack App settings>

# ── Connector config encryption key ──────────────────────────
# AES-256 key used to encrypt connector configs in the database
# Generate with: openssl rand -base64 32
CONNECTOR_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# ── App ───────────────────────────────────────────────────────
BUGPILOT_ENV=development          # development | staging | production
BUGPILOT_BASE_URL=https://api.bugpilot.io
LOG_LEVEL=info                    # debug | info | warn | error
LOG_FORMAT=text                   # text | json
